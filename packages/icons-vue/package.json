{
  "name": "@lumal/icons-vue",
  "type": "module",
  "version": "0.0.1-beta",
  "description": "Vue components and reactive adapters for @lumal/icons.",
  "license": "MIT",
  "keywords": [
    "lumal",
    "vue",
    "icons",
    "iconify",
    "svg"
  ],
  "sideEffects": [
    "**/*.css"
  ],
  "publishConfig": {
    "access": "public"
  },
  "exports": {
    ".": {
      "types": "./dist/src/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    },
    "./style.css": "./dist/icons-vue.css"
  },
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/src/index.d.ts",
  "files": [
    "README.md",
    "dist"
  ],
  "scripts": {
    "build": "vite build --config vite.config.ts && vue-tsc -p tsconfig.json --emitDeclarationOnly --outDir dist && node ../../scripts/clean-package-dist.mjs dist",
    "typecheck": "vue-tsc --noEmit -p tsconfig.json",
    "test": "vitest run --config ../../vitest.config.ts tests"
  },
  "peerDependencies": {
    "@iconify/vue": "^5.0.0",
    "vue": "^3.5.0"
  },
  "dependencies": {
    "@lumal/icons": "0.0.1-beta"
  }
}
